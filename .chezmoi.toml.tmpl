{{/* Per-machine data, derived from the environment. No prompts. */}}
{{- $isWSL := false -}}
{{- if hasKey .chezmoi.kernel "osrelease" -}}
{{-   if or (contains "microsoft" (lower .chezmoi.kernel.osrelease)) (contains "wsl" (lower .chezmoi.kernel.osrelease)) -}}
{{-     $isWSL = true -}}
{{-   end -}}
{{- end -}}
{{- $pkgManager := "unsupported" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $pkgManager = "brew" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   if lookPath "apt-get" -}}
{{-     $pkgManager = "apt" -}}
{{-   else if lookPath "brew" -}}
{{-     $pkgManager = "brew" -}}
{{-   end -}}
{{- end -}}

[data]
    os = {{ .chezmoi.os | quote }}
    arch = {{ .chezmoi.arch | quote }}
    isWSL = {{ $isWSL }}
    pkgManager = {{ $pkgManager | quote }}

# Cache GitHub API responses (gitHubLatestReleaseAssetURL in the externals)
# for one week, to avoid hitting the 60 req/h rate limit on status/apply/verify.
# For CI/containers, export CHEZMOI_GITHUB_ACCESS_TOKEN to raise the limit.
[gitHub]
    refreshPeriod = "168h"
