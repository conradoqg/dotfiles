{{/* Declarative externals: binaries (Linux), oh-my-zsh plugins and the p10k theme.
     macOS installs the binaries via brew (see .chezmoiscripts). Linux only here.
     Arch: chezmoi exposes amd64/arm64. Rust tools use x86_64/aarch64. */}}
{{- $rustArch := "x86_64" -}}
{{- if eq .chezmoi.arch "arm64" }}{{ $rustArch = "aarch64" }}{{ end -}}
{{- $microArch := "linux64" -}}
{{- if eq .chezmoi.arch "arm64" }}{{ $microArch = "linux-arm64" }}{{ end -}}

{{/* ===== oh-my-zsh + plugins + theme (HTTPS, replaces the old git@ SSH) ===== */}}
{{- if ne .chezmoi.os "windows" }}
[".oh-my-zsh"]
    type = "archive"
    url = "https://github.com/ohmyzsh/ohmyzsh/archive/master.tar.gz"
    exact = false
    stripComponents = 1
    refreshPeriod = "168h"

[".oh-my-zsh-custom/plugins/zsh-autosuggestions"]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-autosuggestions/archive/master.tar.gz"
    exact = false
    stripComponents = 1
    refreshPeriod = "168h"

[".oh-my-zsh-custom/plugins/fast-syntax-highlighting"]
    type = "archive"
    url = "https://github.com/zdharma-continuum/fast-syntax-highlighting/archive/master.tar.gz"
    exact = false
    stripComponents = 1
    refreshPeriod = "168h"

[".oh-my-zsh-custom/plugins/fzf-tab"]
    type = "archive"
    url = "https://github.com/Aloxaf/fzf-tab/archive/master.tar.gz"
    exact = false
    stripComponents = 1
    refreshPeriod = "168h"

[".oh-my-zsh-custom/plugins/you-should-use"]
    type = "archive"
    url = "https://github.com/MichaelAquilina/zsh-you-should-use/archive/master.tar.gz"
    exact = false
    stripComponents = 1
    refreshPeriod = "168h"

[".oh-my-zsh-custom/themes/powerlevel10k"]
    type = "archive"
    url = "https://github.com/romkatv/powerlevel10k/archive/master.tar.gz"
    exact = false
    stripComponents = 1
    refreshPeriod = "168h"
{{- end }}

{{/* ===== binaries (Linux only; macOS via brew) ===== */}}
{{- if eq .chezmoi.os "linux" }}
{{- $k8sTag := (gitHubLatestRelease "kubernetes/kubernetes").TagName -}}
{{- $tfVer := trimPrefix "v" (gitHubLatestRelease "hashicorp/terraform").TagName -}}
{{- $rgTriple := (eq .chezmoi.arch "arm64" | ternary "aarch64-unknown-linux-gnu" "x86_64-unknown-linux-musl") -}}

# eza (replaces exa 🪦) — versionless asset name
[".local/bin/eza"]
    type = "archive-file"
    url = "https://github.com/eza-community/eza/releases/latest/download/eza_{{ $rustArch }}-unknown-linux-gnu.tar.gz"
    path = "./eza"
    executable = true
    refreshPeriod = "168h"

# doggo (replaces dog 🪦) — versionless name
[".local/bin/doggo"]
    type = "archive-file"
    url = "https://github.com/mr-karan/doggo/releases/latest/download/doggo-linux-{{ $rustArch }}.tar.gz"
    path = "doggo"
    executable = true
    refreshPeriod = "168h"

# gitui — versionless name
[".local/bin/gitui"]
    type = "archive-file"
    url = "https://github.com/gitui-org/gitui/releases/latest/download/gitui-linux-{{ $rustArch }}.tar.gz"
    path = "./gitui"
    executable = true
    refreshPeriod = "168h"

# k9s — versionless name
[".local/bin/k9s"]
    type = "archive-file"
    url = "https://github.com/derailed/k9s/releases/latest/download/k9s_Linux_{{ .chezmoi.arch }}.tar.gz"
    path = "k9s"
    executable = true
    refreshPeriod = "168h"

# yq (renamed to 'yq' — was yq_linux_amd64) — raw binary
[".local/bin/yq"]
    type = "file"
    url = "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_{{ .chezmoi.arch }}"
    executable = true
    refreshPeriod = "168h"

# walk (adopted) — raw binary
[".local/bin/walk"]
    type = "file"
    url = "https://github.com/antonmedv/walk/releases/latest/download/walk_linux_{{ .chezmoi.arch }}"
    executable = true
    refreshPeriod = "168h"

# jnv (adopted) — cargo-dist, binary at <stem>/jnv
[".local/bin/jnv"]
    type = "archive-file"
    url = "https://github.com/ynqa/jnv/releases/latest/download/jnv-{{ $rustArch }}-unknown-linux-gnu.tar.xz"
    path = "jnv-{{ $rustArch }}-unknown-linux-gnu/jnv"
    executable = true
    refreshPeriod = "168h"

# cloudflare-speed-cli (adopted) — cargo-dist musl
[".local/bin/cloudflare-speed-cli"]
    type = "archive-file"
    url = "https://github.com/kavehtehrani/cloudflare-speed-cli/releases/latest/download/cloudflare-speed-cli-{{ $rustArch }}-unknown-linux-musl.tar.xz"
    path = "cloudflare-speed-cli-{{ $rustArch }}-unknown-linux-musl/cloudflare-speed-cli"
    executable = true
    refreshPeriod = "168h"

# lazygit — version in the asset name → gitHubLatestReleaseAssetURL
[".local/bin/lazygit"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "jesseduffield/lazygit" (printf "lazygit_*_linux_%s.tar.gz" (eq .chezmoi.arch "arm64" | ternary "arm64" "x86_64")) | quote }}
    path = "lazygit"
    executable = true
    refreshPeriod = "168h"

# lazydocker — same pattern (goreleaser), version in the name
[".local/bin/lazydocker"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "jesseduffield/lazydocker" (printf "lazydocker_*_Linux_%s.tar.gz" (eq .chezmoi.arch "arm64" | ternary "arm64" "x86_64")) | quote }}
    path = "lazydocker"
    executable = true
    refreshPeriod = "168h"

# duf — version in the name
[".local/bin/duf"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "muesli/duf" (printf "duf_*_linux_%s.tar.gz" (eq .chezmoi.arch "arm64" | ternary "arm64" "x86_64")) | quote }}
    path = "duf"
    executable = true
    refreshPeriod = "168h"

# ctop — version in the name, raw binary ('file' via asset URL)
[".local/bin/ctop"]
    type = "file"
    url = {{ gitHubLatestReleaseAssetURL "bcicen/ctop" (printf "ctop-*-linux-%s" .chezmoi.arch) | quote }}
    executable = true
    refreshPeriod = "168h"

# fzf — version in the name
[".local/bin/fzf"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "junegunn/fzf" (printf "fzf-*-linux_%s.tar.gz" .chezmoi.arch) | quote }}
    path = "fzf"
    executable = true
    refreshPeriod = "168h"

# micro — version in the name + binary at micro-<ver>/micro
[".local/bin/micro"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "zyedidia/micro" (printf "micro-*-%s.tar.gz" $microArch) | quote }}
    path = "micro"
    stripComponents = 1
    executable = true
    refreshPeriod = "168h"

# broot — Canop zip, binary at <triple>/broot
[".local/bin/broot"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "Canop/broot" "broot_*.zip" | quote }}
    path = "{{ $rustArch }}-unknown-linux-gnu/broot"
    executable = true
    refreshPeriod = "168h"

# dysk (adopted) — Canop zip, binary at build/<triple>/dysk
[".local/bin/dysk"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "Canop/dysk" "dysk_*.zip" | quote }}
    path = "build/{{ $rustArch }}-unknown-linux-gnu/dysk"
    executable = true
    refreshPeriod = "168h"

# ripgrep — libc differs per arch (musl on amd64, gnu on arm64)
[".local/bin/rg"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "BurntSushi/ripgrep" (printf "ripgrep-*-%s.tar.gz" $rgTriple) | quote }}
    path = "rg"
    stripComponents = 1
    executable = true
    refreshPeriod = "168h"

# zoxide — musl, binary at archive root
[".local/bin/zoxide"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "ajeetdsouza/zoxide" (printf "zoxide-*-%s-unknown-linux-musl.tar.gz" $rustArch) | quote }}
    path = "zoxide"
    executable = true
    refreshPeriod = "168h"

# git-delta — gnu, binary in delta-<ver>-<triple>/delta
[".local/bin/delta"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "dandavison/delta" (printf "delta-*-%s-unknown-linux-gnu.tar.gz" $rustArch) | quote }}
    path = "delta"
    stripComponents = 1
    executable = true
    refreshPeriod = "168h"

# miniserve — raw binary (adopted; has a browser upload UI)
[".local/bin/miniserve"]
    type = "file"
    url = {{ gitHubLatestReleaseAssetURL "svenstaro/miniserve" (printf "miniserve-*-%s-unknown-linux-gnu" $rustArch) | quote }}
    executable = true
    refreshPeriod = "168h"

# fortio — HTTP/gRPC load testing; binary in usr/bin/fortio
[".local/bin/fortio"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "fortio/fortio" (printf "fortio-linux_%s-*.tgz" .chezmoi.arch) | quote }}
    path = "usr/bin/fortio"
    executable = true
    refreshPeriod = "168h"

# globalping — network measurements (ping/traceroute/DNS/HTTP) from a global probe network
[".local/bin/globalping"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "jsdelivr/globalping-cli" (printf "globalping_Linux_%s.tar.gz" (eq .chezmoi.arch "arm64" | ternary "arm64" "x86_64")) | quote }}
    path = "globalping"
    executable = true
    refreshPeriod = "168h"

# ngrok — secure tunnels (run `ngrok config add-authtoken <token>` once; the token
# is a secret and is NOT versioned). Binary from equinox (not GitHub); arch = amd64/arm64.
[".local/bin/ngrok"]
    type = "archive-file"
    url = "https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-{{ .chezmoi.arch }}.tgz"
    path = "ngrok"
    executable = true
    refreshPeriod = "168h"

# kubectl — official binary from dl.k8s.io (stable tag via GitHub)
[".local/bin/kubectl"]
    type = "file"
    url = "https://dl.k8s.io/release/{{ $k8sTag }}/bin/linux/{{ .chezmoi.arch }}/kubectl"
    executable = true
    refreshPeriod = "168h"

# terraform — HashiCorp zip (BSL license); version via GitHub tag
[".local/bin/terraform"]
    type = "archive-file"
    url = "https://releases.hashicorp.com/terraform/{{ $tfVer }}/terraform_{{ $tfVer }}_linux_{{ .chezmoi.arch }}.zip"
    path = "terraform"
    executable = true
    refreshPeriod = "168h"

# mise — polyglot runtime/tool version manager (asdf-compatible). Raw binary.
[".local/bin/mise"]
    type = "file"
    url = {{ gitHubLatestReleaseAssetURL "jdx/mise" (printf "mise-*-linux-%s" (eq .chezmoi.arch "arm64" | ternary "arm64" "x64")) | quote }}
    executable = true
    refreshPeriod = "168h"
{{- end }}
