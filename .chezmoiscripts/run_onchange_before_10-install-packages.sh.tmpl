#!/bin/bash
# Installs packages from the native package manager. Re-runs automatically when
# the list below changes (the rendered content is part of the run_onchange hash).
#
#   os         = {{ .os }}
#   arch       = {{ .arch }}
#   pkgManager = {{ .pkgManager }}
#
# On Linux, the modern binaries (eza, lazygit, ...) come from .chezmoiexternal.toml;
# here only what the native package manager covers. On macOS, brew covers everything.
set -euo pipefail

SUDO=""
if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
    SUDO="sudo"
fi

{{ if eq .pkgManager "apt" -}}
export DEBIAN_FRONTEND=noninteractive
PACKAGES=(
    wget git zsh vim tree most ncdu htop
    git-extras git-flow direnv zip unzip mtr-tiny
    jq
    bat fd-find
    btop
)
echo "==> apt: updating index"
$SUDO apt-get update -qq
echo "==> apt: installing ${#PACKAGES[@]} packages"
$SUDO apt-get install -y --no-install-recommends "${PACKAGES[@]}"

{{ else if eq .pkgManager "brew" -}}
# macOS (and Linuxbrew): brew covers base + modern binaries, since the binary
# externals are Linux-only.
brew tap hashicorp/tap >/dev/null 2>&1 || true
PACKAGES=(
    git zsh
    eza doggo gitui lazygit lazydocker duf yq ctop k9s micro broot fzf
    walk dysk jnv
    btop bat fd
    ripgrep zoxide git-delta miniserve fortio kubernetes-cli
    tree ncdu htop mtr jq direnv git-extras git-flow
    hashicorp/tap/terraform
)
echo "==> brew: installing ${#PACKAGES[@]} formulae"
brew install "${PACKAGES[@]}" || true

{{ else -}}
echo "WARNING: pkgManager '{{ .pkgManager }}' is not supported on this OS ({{ .os }})." >&2
echo "         Install manually: zsh, git, btop, bat, fd, and an editor." >&2
{{ end -}}

# Make zsh the default shell (idempotent; ignores failure where chsh/PAM is absent)
if command -v zsh >/dev/null 2>&1; then
    zsh_path="$(command -v zsh)"
    current_shell="$(getent passwd "$(id -un)" 2>/dev/null | cut -d: -f7 || echo "")"
    if [ "$current_shell" != "$zsh_path" ]; then
        echo "==> setting zsh as the default shell"
        $SUDO chsh -s "$zsh_path" "$(id -un)" 2>/dev/null \
            || chsh -s "$zsh_path" 2>/dev/null \
            || echo "   (could not change the shell automatically; ignore inside a container)"
    fi
fi
